# Canonical app origin for links and deployment configuration.
# Use the real deployed origin in preview/production, not localhost.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Protects POST /api/cron/run-scheduled. Required outside development.
# Callers must send: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=replace-for-production

# Comma-separated admin email allowlist for /admin and /api/admin/health.
ADMIN_EMAILS=admin@example.com

# Local development only. When true, reset tokens can be displayed after request.
WEB_AUDIT_DEV_RESET_TOKENS=false
