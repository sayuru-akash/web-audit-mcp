# Canonical app origin for links and deployment configuration.
# Use the real deployed origin in preview/production, not localhost.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Protects POST /api/cron/run-scheduled. Required outside development.
# Callers must send: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=replace-for-production

# Comma-separated admin email allowlist for /admin and /api/admin/health.
ADMIN_EMAILS=admin@example.com

# Local development only. When true, reset tokens can be displayed after request.
WEB_AUDIT_DEV_RESET_TOKENS=false

# Optional staged Postgres persistence path.
# When DATABASE_URL is set, the app begins selecting the Postgres store adapter.
# Current status: only the initial auth/session-related adapter work is being wired.
# Leave this unset unless you are actively finishing the Postgres migration.
# JSON storage in data/webaudit.json remains the safe default runtime path today.
# DATABASE_URL=postgresql://user:password@host:5432/web_audit
